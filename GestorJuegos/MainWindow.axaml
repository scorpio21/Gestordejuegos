<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:GestorJuegos.Models"
        xmlns:utils="clr-namespace:GestorJuegos.Utils"
        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="700"
        x:Class="GestorJuegos.MainWindow"
        Title="Gestor de Juegos"
        Background="#0f172a" Foreground="#f8fafc"
        WindowStartupLocation="CenterScreen">
        
    <Window.Resources>
        <utils:ByteArrayToBitmapConverter x:Key="ByteToBitmap" />
        <SolidColorBrush x:Key="AccentBrush">#6366f1</SolidColorBrush>
        <SolidColorBrush x:Key="PanelBrush">#1e293b</SolidColorBrush>
    </Window.Resources>

    <Grid>
        <DockPanel>
            <!-- Top Navigation Bar -->
            <Border DockPanel.Dock="Top" Background="{StaticResource PanelBrush}" Height="50" Padding="15,0" BorderBrush="#334155" BorderThickness="0,0,0,1">
                <DockPanel>
                    <TextBlock Text="🎮 Colección Retro" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" Foreground="#e2e8f0"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" VerticalAlignment="Center">
                        <Menu Background="Transparent">
                            <MenuItem Header="Plataformas ⏷" Name="MenuPlataformas" FontSize="14" Foreground="#cbd5e1"/>
                        </Menu>
                        <Button Name="BtnManagePlatforms" Content="⚙️ Gestionar" Background="Transparent" Foreground="#cbd5e1" CornerRadius="6" Padding="10,5" FontWeight="SemiBold" BorderThickness="1" BorderBrush="#334155"/>
                        <Button Name="BtnAddPlatform" Content="+ Añadir Plataforma" Background="{StaticResource AccentBrush}" Foreground="White" CornerRadius="6" Padding="10,5" FontWeight="SemiBold" BorderThickness="0"/>
                    </StackPanel>
                </DockPanel>
            </Border>
            
            <Grid ColumnDefinitions="*, 350">
                <!-- Main Content Panel -->
                <Border Grid.Column="0" Padding="20">
                    <DockPanel>
                        <!-- Header with View Toggles -->
                        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,20">
                            <TextBlock Name="TxtSelectedPlatform" Text="Seleccione una plataforma" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                                <Button Name="BtnViewList" Content="≡ Lista" Padding="10,6" Background="#334155" Foreground="White" CornerRadius="6"/>
                                <Button Name="BtnViewGrid" Content="▤ Galería" Padding="10,6" Background="Transparent" Foreground="#94a3b8" CornerRadius="6" BorderBrush="#334155" BorderThickness="1"/>
                            </StackPanel>
                        </DockPanel>
                        
                        <!-- Main Views -->
                        <Panel>
                            <!-- List View -->
                            <ListBox Name="LstGames" Background="Transparent" BorderThickness="0">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="models:Game">
                                        <Border Background="{StaticResource PanelBrush}" CornerRadius="8" Margin="0,0,0,8" Padding="10">
                                            <Grid ColumnDefinitions="Auto, *, Auto, Auto">
                                                <Border Grid.Column="0" CornerRadius="4" ClipToBounds="True" Margin="0,0,15,0">
                                                    <Image Source="{Binding Cover, Converter={StaticResource ByteToBitmap}}" Width="45" Height="60" Stretch="UniformToFill"/>
                                                </Border>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="16" Margin="0,0,0,4"/>
                                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                                        <TextBlock Text="{Binding Genre}" Foreground="#94a3b8" FontSize="13"/>
                                                        <TextBlock Text="•" Foreground="#475569"/>
                                                        <TextBlock Text="{Binding Year}" Foreground="#94a3b8" FontSize="13"/>
                                                        <TextBlock Text="•" Foreground="#475569"/>
                                                        <TextBlock Text="{Binding Languages}" Foreground="#94a3b8" FontSize="13"/>
                                                    </StackPanel>
                                                </StackPanel>
                                                <TextBlock Grid.Column="2" Text="{Binding Region}" VerticalAlignment="Center" FontSize="24" Margin="0,0,15,0"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <!-- Grid View -->
                            <ListBox Name="LstGamesGrid" Background="Transparent" IsVisible="False" BorderThickness="0">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel ItemWidth="140" />
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="models:Game">
                                        <Border Background="{StaticResource PanelBrush}" CornerRadius="8" Margin="8" Padding="10">
                                            <StackPanel Spacing="8">
                                                <Border CornerRadius="4" ClipToBounds="True" Height="150">
                                                    <Image Source="{Binding Cover, Converter={StaticResource ByteToBitmap}}" Stretch="UniformToFill" />
                                                </Border>
                                                <TextBlock Text="{Binding Name}" FontWeight="Bold" TextAlignment="Center" TextWrapping="Wrap" MaxLines="2" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Region}" TextAlignment="Center" FontSize="18"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Panel>
                    </DockPanel>
                </Border>
                
                <!-- Right Side Panel (Details) -->
                <Border Grid.Column="1" Background="{StaticResource PanelBrush}" BorderBrush="#334155" BorderThickness="1,0,0,0" Padding="20">
                    <DockPanel>
                        <Button Name="BtnAddGame" Content="+ Añadir Nuevo Juego" DockPanel.Dock="Top" Background="#10b981" Foreground="White" FontWeight="Bold" CornerRadius="6" Padding="10" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="0,0,0,20"/>
                        
                        <ScrollViewer Padding="0,0,15,0">
                            <StackPanel Name="PnlGameDetails" IsVisible="False" Spacing="15" Margin="0,0,5,0">
                                <TextBlock Text="Detalles del Juego" FontSize="20" FontWeight="Bold" Margin="0,0,0,10" Foreground="#e2e8f0"/>
                                
                                <TextBlock Text="Nombre" Foreground="#94a3b8" FontSize="12" Margin="0,0,0,-10"/>
                                <TextBox Name="TxtName" CornerRadius="4" Background="#0f172a" BorderBrush="#334155"/>
                                
                                <Grid ColumnDefinitions="*,*">
                                    <StackPanel Grid.Column="0" Margin="0,0,5,0" Spacing="5">
                                        <TextBlock Text="Año" Foreground="#94a3b8" FontSize="12"/>
                                        <NumericUpDown Name="NumYear" CornerRadius="4" Background="#0f172a" BorderBrush="#334155" Minimum="1950" Maximum="2100" FormatString="0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="5,0,0,0" Spacing="5">
                                        <TextBlock Text="Región" Foreground="#94a3b8" FontSize="12"/>
                                        <ComboBox Name="CmbRegion" CornerRadius="4" Background="#0f172a" BorderBrush="#334155" HorizontalAlignment="Stretch" SelectedIndex="0">
                                            <ComboBoxItem Content="🇺🇸 US" />
                                            <ComboBoxItem Content="🇪🇺 EU" />
                                            <ComboBoxItem Content="🇯🇵 JP" />
                                            <ComboBoxItem Content="🌎 World" />
                                        </ComboBox>
                                    </StackPanel>
                                </Grid>
                                
                                <TextBlock Text="Género" Foreground="#94a3b8" FontSize="12" Margin="0,0,0,-10"/>
                                <TextBox Name="TxtGenre" CornerRadius="4" Background="#0f172a" BorderBrush="#334155"/>

                                <TextBlock Text="Idiomas (Ej. En,Fr,Es)" Foreground="#94a3b8" FontSize="12" Margin="0,0,0,-10"/>
                                <TextBox Name="TxtLanguages" CornerRadius="4" Background="#0f172a" BorderBrush="#334155"/>
                                
                                <TextBlock Text="Carátula" Foreground="#94a3b8" FontSize="12" Margin="0,10,0,0"/>
                                <Border BorderBrush="#334155" BorderThickness="1" CornerRadius="6" Height="250" Background="#0f172a" ClipToBounds="True">
                                    <Image Name="ImgCover" Stretch="UniformToFill"/>
                                </Border>
                                <Grid ColumnDefinitions="*,*">
                                    <Button Grid.Column="0" Name="BtnSelectCover" Content="Seleccionar" Margin="0,0,5,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="#334155" CornerRadius="4"/>
                                    <Button Grid.Column="1" Name="BtnClearCover" Content="Quitar" Margin="5,0,0,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="#334155" CornerRadius="4"/>
                                </Grid>
                                
                                <Grid ColumnDefinitions="*,*" Margin="0,20,0,0">
                                    <Button Grid.Column="0" Name="BtnDelete" Content="Eliminar" Margin="0,0,5,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="#ef4444" Foreground="White" FontWeight="Bold" CornerRadius="4"/>
                                    <Button Grid.Column="1" Name="BtnSave" Content="Guardar" Margin="5,0,0,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="{StaticResource AccentBrush}" Foreground="White" FontWeight="Bold" CornerRadius="4"/>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </Grid>
        </DockPanel>
        
        <!-- Add Platform Overlay -->
        <Border Name="OverlayAddPlatform" Background="#AA000000" IsVisible="False" ZIndex="100">
            <Border Background="{StaticResource PanelBrush}" Width="400" VerticalAlignment="Center" HorizontalAlignment="Center" CornerRadius="12" Padding="25" BorderBrush="#334155" BorderThickness="1">
                <StackPanel Spacing="15">
                    <TextBlock Text="Añadir Nueva Plataforma" FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,0,0,10"/>
                    <TextBlock Text="Nombre de la Plataforma (Ej. PlayStation 1)" Foreground="#94a3b8" FontSize="14"/>
                    <TextBox Name="TxtNewPlatformName" CornerRadius="6" Background="#0f172a" BorderBrush="#334155" FontSize="16" Padding="10"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,15,0,0">
                        <Button Name="BtnCancelPlatform" Content="Cancelar" Background="Transparent" Foreground="#cbd5e1" CornerRadius="6" Padding="15,8"/>
                        <Button Name="BtnSavePlatform" Content="Guardar Plataforma" Background="{StaticResource AccentBrush}" Foreground="White" FontWeight="Bold" CornerRadius="6" Padding="15,8"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
        
        <!-- Message Overlay -->
        <Border Name="OverlayMessage" Background="#AA000000" IsVisible="False" ZIndex="200">
            <Border Background="{StaticResource PanelBrush}" Width="350" VerticalAlignment="Center" HorizontalAlignment="Center" CornerRadius="12" Padding="25" BorderBrush="#334155" BorderThickness="1">
                <StackPanel Spacing="15">
                    <TextBlock Text="Aviso" FontSize="20" FontWeight="Bold" Foreground="#fbbf24" Margin="0,0,0,5" HorizontalAlignment="Center"/>
                    <TextBlock Name="TxtMessageContent" Text="Mensaje de error." Foreground="#e2e8f0" FontSize="15" TextWrapping="Wrap" TextAlignment="Center"/>
                    <Button Name="BtnCloseMessage" Content="Entendido" Background="{StaticResource AccentBrush}" Foreground="White" FontWeight="Bold" CornerRadius="6" Padding="20,8" HorizontalAlignment="Center" Margin="0,15,0,0"/>
                </StackPanel>
            </Border>
        </Border>

        <!-- Manage Platforms Overlay -->
        <Border Name="OverlayManagePlatforms" Background="#AA000000" IsVisible="False" ZIndex="150">
            <Border Background="{StaticResource PanelBrush}" Width="450" Height="500" VerticalAlignment="Center" HorizontalAlignment="Center" CornerRadius="12" Padding="25" BorderBrush="#334155" BorderThickness="1">
                <DockPanel>
                    <TextBlock Text="Gestionar Plataformas" FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,0,0,15" DockPanel.Dock="Top"/>
                    
                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,20,0,0">
                        <Button Name="BtnCloseManagePlatforms" Content="Cerrar" Background="Transparent" Foreground="#cbd5e1" CornerRadius="6" Padding="15,8"/>
                    </StackPanel>

                    <!-- Edit Section -->
                    <StackPanel Name="PnlEditPlatform" DockPanel.Dock="Bottom" IsVisible="False" Spacing="10" Margin="0,20,0,0">
                        <TextBlock Text="Editar Nombre:" Foreground="#94a3b8" FontSize="14"/>
                        <TextBox Name="TxtEditPlatformName" CornerRadius="6" Background="#0f172a" BorderBrush="#334155" FontSize="16" Padding="8"/>
                        <Grid ColumnDefinitions="*,*">
                            <Button Grid.Column="0" Name="BtnDeletePlatform" Content="Eliminar" Background="#ef4444" Foreground="White" FontWeight="Bold" CornerRadius="6" Padding="10" Margin="0,0,5,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                            <Button Grid.Column="1" Name="BtnSaveEditPlatform" Content="Guardar" Background="{StaticResource AccentBrush}" Foreground="White" FontWeight="Bold" CornerRadius="6" Padding="10" Margin="5,0,0,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                        </Grid>
                    </StackPanel>

                    <ListBox Name="LstManagePlatforms" Background="#0f172a" CornerRadius="6" BorderBrush="#334155" BorderThickness="1">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="models:Platform">
                                <TextBlock Text="{Binding Name}" Padding="5" Foreground="#e2e8f0"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>
        </Border>
    </Grid>
</Window>
