<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:GestorVimm"
        x:Class="GestorVimm.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="960" Height="720"
        Title="GestorVimm - Carátulas desde Vimm.net">

	<Grid RowDefinitions="Auto,Auto,*,Auto" Margin="12" RowSpacing="8">
		<StackPanel Spacing="6">
			<TextBlock Text="Plataforma (The Vault)" FontWeight="SemiBold"/>
			<ComboBox ItemsSource="{Binding Platforms}"
					  SelectedItem="{Binding SelectedPlatform}"
					  HorizontalAlignment="Stretch">
				<ComboBox.ItemTemplate>
					<DataTemplate>
						<TextBlock Text="{Binding Name}"/>
					</DataTemplate>
				</ComboBox.ItemTemplate>
			</ComboBox>
		</StackPanel>

		<StackPanel Grid.Row="1" Spacing="6">
			<TextBlock Text="Listado de ROMs (.txt, un juego por línea)" FontWeight="SemiBold"/>
			<Border x:Name="TxtDropZone"
					DragDrop.AllowDrop="True"
					BorderBrush="#555"
					BorderThickness="1"
					CornerRadius="4"
					Padding="4">
				<Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
					<StackPanel Grid.Column="0" Spacing="2">
						<TextBox Text="{Binding TxtFilePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
								 PlaceholderText="Ruta al .txt o arrastra el fichero aquí"/>
						<TextBlock Text="Arrastra y suelta un .txt en esta zona"
								   FontSize="10"
								   Opacity="0.55"/>
					</StackPanel>
					<Button Grid.Column="1" Content="Elegir .txt" Command="{Binding PickTxtCommand}"/>
					<Button Grid.Column="2" Content="Analizar" Command="{Binding ParseTxtCommand}"/>
				</Grid>
			</Border>
			<Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
				<TextBox Text="{Binding OutputFolder, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
						 PlaceholderText="Carpeta de salida para las carátulas"/>
				<Button Grid.Column="1" Content="Carpeta salida" Command="{Binding PickFolderCommand}"/>
			</Grid>
			<StackPanel Orientation="Horizontal" Spacing="8">
				<Button Content="Descargar carátulas"
						Command="{Binding DownloadCoversCommand}"/>
				<Button Content="Cancelar descarga"
						Command="{Binding CancelDownloadCommand}"/>
			</StackPanel>
			<TextBlock Text="{Binding StatusHint}" Opacity="0.85" FontSize="12"/>
			<StackPanel Spacing="4" IsVisible="{Binding ShowProgress}">
				<TextBlock Text="{Binding ProgressText}"
						   HorizontalAlignment="Center"
						   FontSize="12"
						   FontWeight="SemiBold"/>
				<ProgressBar Minimum="0"
							 Maximum="{Binding ProgressMaximum}"
							 Value="{Binding ProgressCurrent}"
							 Height="22"/>
			</StackPanel>
		</StackPanel>

		<Grid Grid.Row="2" ColumnDefinitions="*,280" ColumnSpacing="10">
			<Border BorderBrush="Gray" BorderThickness="1" Padding="6">
				<ScrollViewer>
					<TextBox Text="{Binding LogText}"
							 IsReadOnly="True"
							 AcceptsReturn="True"
							 TextWrapping="Wrap"
							 BorderThickness="0"
							 Background="Transparent"/>
				</ScrollViewer>
			</Border>
			<StackPanel Grid.Column="1" Spacing="6">
				<TextBlock Text="Vista previa" FontWeight="SemiBold"/>
				<Border BorderBrush="Gray" BorderThickness="1" MinHeight="200">
					<Image Source="{Binding PreviewCover}"
						   Stretch="Uniform"
						   HorizontalAlignment="Center"
						   VerticalAlignment="Center"/>
				</Border>
				<TextBlock Text="{Binding PreviewCaption}"
						   TextWrapping="Wrap"
						   FontSize="11"
						   Opacity="0.9"/>
				<StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
					<Button Content="◀ Anterior" Command="{Binding PrevCoverCommand}" Padding="8,4"/>
					<Button Content="Siguiente ▶" Command="{Binding NextCoverCommand}" Padding="8,4"/>
				</StackPanel>
				<TextBlock Text="Juegos detectados (clic para ver carátula):" FontWeight="SemiBold"/>
				<ListBox ItemsSource="{Binding ParsedGames}"
						 SelectedItem="{Binding SelectedGame}"
						 MaxHeight="240">
					<ListBox.ItemTemplate>
						<DataTemplate>
							<Grid ColumnDefinitions="Auto,*">
								<TextBlock Grid.Column="0"
										   Text="✓"
										   Foreground="LimeGreen"
										   Margin="0,0,6,0"
										   IsVisible="{Binding HasCover}"/>
								<StackPanel Grid.Column="1">
									<TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
									<TextBlock FontSize="11" Opacity="0.8">
										<TextBlock.Text>
											<MultiBinding StringFormat="Región: {0}  |  Idiomas: {1}">
												<Binding Path="Region"/>
												<Binding Path="Languages"/>
											</MultiBinding>
										</TextBlock.Text>
									</TextBlock>
									<TextBlock Text="existente"
											   FontSize="10"
											   Foreground="SkyBlue"
											   IsVisible="{Binding IsExistingCover}"/>
								</StackPanel>
							</Grid>
						</DataTemplate>
					</ListBox.ItemTemplate>
				</ListBox>
			</StackPanel>
		</Grid>

		<TextBlock Grid.Row="3" Opacity="0.7" FontSize="11" TextWrapping="Wrap"
				   Text="Formato esperado: Nombre del juego (Región) (Idiomas).zip — Ej.: Sushi Striker - The Way of Sushido (Europe) (En,Fr,De,Es,It,Nl).zip"/>
	</Grid>
</Window>
