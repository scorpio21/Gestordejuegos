<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fluent="using:Avalonia.Themes.Fluent"
             x:Class="GestorVimm.App">

	<Application.Styles>
		<fluent:FluentTheme />
		<Style Selector="Border.drag-over">
			<Setter Property="BorderBrush" Value="#4a9eff"/>
			<Setter Property="Background" Value="#334a9eff"/>
		</Style>
	</Application.Styles>

</Application>

